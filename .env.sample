# Database dialect: "mysql" (default) or "postgres" (opt-in)
# DB_DIALECT=mysql

# MySQL settings (default)
MYSQL_ROOT_PASSWORD=b1stack_root
MYSQL_USER=b1stack
MYSQL_PASSWORD=b1stack_pass

# PostgreSQL settings (used when DB_DIALECT=postgres)
# PG_USER=b1stack
# PG_PASSWORD=b1stack_pass

# Required secrets — change before first run
ENCRYPTION_KEY=change__me__24__chars!!!   # exactly 24 characters (192-bit AES key)
JWT_SECRET=change-me-in-production-please

# Mailpit port overrides (if defaults 8025/1025 conflict with other projects)
# MAILPIT_UI_PORT=8026
# MAILPIT_SMTP_PORT=1026

# Optional third-party keys (leave blank to disable features)
YOUTUBE_API_KEY=
PEXELS_KEY=
VIMEO_TOKEN=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GOOGLE_RECAPTCHA_SECRET_KEY=
NEXT_PUBLIC_YOUVERSION_API_KEY=
