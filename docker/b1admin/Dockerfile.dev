FROM node:22-alpine
WORKDIR /app

# Install dependencies first for layer caching
COPY services/B1Admin/package.json services/B1Admin/package-lock.json ./
# npm install (not ci) — upstream lock file drifts frequently
RUN npm install && npm run postinstall

# Copy build config (not hot-reloaded)
COPY services/B1Admin/vite.config.ts ./
COPY services/B1Admin/tsconfig.json services/B1Admin/tsconfig.app.json services/B1Admin/tsconfig.node.json ./
COPY services/B1Admin/index.html services/B1Admin/eslint.config.js ./

# src/ and public/ are volume-mounted at runtime for HMR
# Note: REACT_APP_* env vars are read at dev-server start — container restart required to pick up changes
EXPOSE 3101

CMD ["npm", "start"]
